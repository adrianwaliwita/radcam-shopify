{% comment %}
  RADCam cart drawer items with quantity controls and remove button
{% endcomment %}

<style>
  .cart-drawer-item {
    display: flex;
    gap: 16px;
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid #e1e4e8;
  }

  .cart-drawer-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  .cart-drawer-item__image {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .cart-drawer-item__details {
    flex: 1;
    min-width: 0;
  }

  .cart-drawer-item__title {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 4px;
    color: #000000;
  }

  .cart-drawer-item__title a {
    color: inherit;
    text-decoration: none;
  }

  .cart-drawer-item__title a:hover {
    color: #facc15;
  }

  .cart-drawer-item__variant {
    font-size: 13px;
    color: #6e7781;
    margin-bottom: 8px;
  }

  .cart-drawer-item__price {
    font-size: 15px;
    font-weight: 600;
    color: #000000;
    margin-bottom: 12px;
  }

  .cart-drawer-item__actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 8px;
  }

  /* Quantity Input */
  .cart-drawer-item .quantity {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid #d0d7de;
    border-radius: 6px;
    padding: 4px;
    background: #ffffff;
  }

  .cart-drawer-item .quantity__button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #57606a;
    transition: color 0.2s;
  }

  .cart-drawer-item .quantity__button:hover:not(:disabled) {
    color: #000000;
  }

  .cart-drawer-item .quantity__button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cart-drawer-item .quantity__button svg {
    width: 12px;
    height: 12px;
  }

  .cart-drawer-item .quantity__input {
    border: none;
    width: 40px;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    color: #000000;
    -moz-appearance: textfield;
    pointer-events: none;
  }

  .cart-drawer-item .quantity__input::-webkit-outer-spin-button,
  .cart-drawer-item .quantity__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart-drawer-item .quantity__input:focus {
    outline: none;
  }

  /* Remove Button */
  .cart-drawer-item .remove-button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #57606a;
    transition: color 0.2s;
  }

  .cart-drawer-item .remove-button:hover:not(:disabled) {
    color: #d73a49;
  }

  .cart-drawer-item .remove-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cart-drawer-item .remove-button svg {
    width: 16px;
    height: 16px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
</style>

{%- for item in cart.items -%}
  <div class="cart-drawer-item" id="cart-item-{{ item.key }}">
    {%- if item.image -%}
      <img class="cart-drawer-item__image" src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" loading="lazy">
    {%- endif -%}

    <div class="cart-drawer-item__details">
      <div class="cart-drawer-item__title">
        <a href="{{ item.url }}">{{ item.product.title }}</a>
      </div>

      {%- if item.variant.title != 'Default Title' -%}
        <div class="cart-drawer-item__variant">{{ item.variant.title }}</div>
      {%- endif -%}

      <div class="cart-drawer-item__price">
        {{ item.final_line_price | money }}
      </div>

      <div class="cart-drawer-item__actions">
        <div class="quantity">
          <button
            class="quantity__button"
            type="button"
            onclick="updateCartQuantity('{{ item.key }}', {{ item.quantity | minus: 1 }})"
            {% if item.quantity <= 1 %}disabled{% endif %}
            aria-label="Decrease quantity"
          >
            <span class="visually-hidden">Decrease quantity for {{ item.product.title | escape }}</span>
            {% render 'icon-minus' %}
          </button>
          <input
            class="quantity__input"
            type="number"
            value="{{ item.quantity }}"
            min="0"
            readonly
            aria-label="Quantity for {{ item.product.title | escape }}"
          >
          <button
            class="quantity__button"
            type="button"
            onclick="updateCartQuantity('{{ item.key }}', {{ item.quantity | plus: 1 }})"
            aria-label="Increase quantity"
          >
            <span class="visually-hidden">Increase quantity for {{ item.product.title | escape }}</span>
            {% render 'icon-plus' %}
          </button>
        </div>

        <button
          class="remove-button"
          type="button"
          onclick="removeCartItem('{{ item.key }}')"
          aria-label="Remove {{ item.title | escape }}"
        >
          {% render 'icon-remove' %}
        </button>
      </div>
    </div>
  </div>
{%- endfor -%}

<script>
  // Update cart item quantity
  window.updateCartQuantity = function(key, quantity) {
    if (quantity < 1) return; // Don't allow quantity less than 1

    // Disable all buttons while updating
    document.querySelectorAll('.cart-drawer-item button').forEach(btn => btn.disabled = true);

    fetch('/cart/change.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        id: key,
        quantity: quantity
      })
    })
    .then(response => response.json())
    .then(data => {
      // Refresh the cart drawer
      if (window.updateRadcamCartDrawer) {
        window.updateRadcamCartDrawer();
      }
    })
    .catch(error => {
      console.error('Error updating cart:', error);
      // Re-enable buttons on error
      document.querySelectorAll('.cart-drawer-item button').forEach(btn => btn.disabled = false);
    });
  }

  // Remove cart item
  window.removeCartItem = function(key) {
    // Disable all buttons while updating
    document.querySelectorAll('.cart-drawer-item button').forEach(btn => btn.disabled = true);

    fetch('/cart/change.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        id: key,
        quantity: 0
      })
    })
    .then(response => response.json())
    .then(data => {
      // Refresh the cart drawer
      if (window.updateRadcamCartDrawer) {
        window.updateRadcamCartDrawer();
      }
    })
    .catch(error => {
      console.error('Error removing item:', error);
      // Re-enable buttons on error
      document.querySelectorAll('.cart-drawer-item button').forEach(btn => btn.disabled = false);
    });
  }
</script>
