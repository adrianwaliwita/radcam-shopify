{% comment %}
  RADCam App Download Page - Shopify Template
  This template integrates with your Shopify theme's header and footer
{% endcomment %}

{% assign radcam_product = all_products['radcam-the-talking-camera-pre-order-now'] %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Inter+Tight:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
    :root {
        --color-black: #000000;
        --color-white: #ffffff;
        --color-accent: #facc15;
        --color-accent-hover: #f5c400;
        --color-canvas-default: #ffffff;
        --color-canvas-subtle: #f6f8fa;
        --color-border-default: #d0d7de;
        --color-border-muted: #e1e4e8;
        --color-fg-default: #0d1117;
        --color-fg-muted: #57606a;
        --color-fg-subtle: #6e7781;
        --container-max: 1280px;
        --container-padding: 32px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24);
        --shadow-md: 0 14px 28px rgba(0,0,0,0.15), 0 10px 10px rgba(0,0,0,0.12);
        --shadow-lg: 0 24px 80px rgba(0,0,0,0.1);
        --shadow-yellow: 0 4px 12px rgba(250,204,21,0.2);
        --shadow-yellow-lg: 0 16px 32px rgba(250,204,21,0.3);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
        font-size: 17px;
        line-height: 1.6;
        color: var(--color-fg-default) !important;
        background: var(--color-white);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
        line-height: 1.15;
        font-weight: 500;
    }

    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; display: block; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; }

    .container {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 var(--container-padding);
    }

    .section { padding: 120px 0; }
    .section-sm { padding: 80px 0; }

    /* BUTTONS */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 22px;
        border-radius: 6px;
        font-size: 15px;
        font-weight: 600;
        transition: all 0.2s;
        white-space: nowrap;
        cursor: pointer;
    }

    .btn-yellow {
        background: var(--color-accent);
        color: var(--color-black);
        border: 1px solid var(--color-accent);
    }

    .btn-yellow:hover {
        background: var(--color-accent-hover);
        transform: translateY(-1px);
        box-shadow: var(--shadow-yellow);
    }

    .btn-primary {
        background: var(--color-black);
        color: var(--color-white);
        border: 1px solid var(--color-black);
    }

    .btn-primary:hover {
        background: #1a1a1a;
        transform: translateY(-1px);
        box-shadow: var(--shadow-sm);
    }

    .btn-lg { padding: 14px 32px; font-size: 16px; }

    /* HERO */
    .hero {
        position: relative;
        min-height: 640px;
        display: flex;
        align-items: center;
        background: url('https://radcam.ai/cdn/shop/files/13_RADCam_Exterior_Garage.jpg?v=1741641305') center center / cover no-repeat;
        color: var(--color-white);
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.75);
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        padding: 100px 0;
        text-align: center;
        max-width: 860px;
        margin: 0 auto;
    }

    .hero-badge {
        display: inline-block;
        padding: 6px 14px;
        background: rgba(250,204,21,0.12);
        border: 1px solid var(--color-accent);
        border-radius: 4px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
        margin-bottom: 28px;
    }

    .hero h1 {
        font-size: 64px;
        letter-spacing: -0.04em;
        margin-bottom: 24px;
        line-height: 1.1;
        font-weight: 600;
        color: var(--color-white) !important;
    }

    .hero h1 .accent { color: var(--color-accent) !important; }

    .hero-description {
        font-size: 20px;
        line-height: 1.6;
        color: rgba(255,255,255,0.78);
        max-width: 640px;
        margin: 0 auto 40px;
    }

    .hero-buttons {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .store-btn {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 14px 24px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.2s;
        cursor: pointer;
        border: 1px solid rgba(255,255,255,0.2);
        background: rgba(255,255,255,0.08);
        color: var(--color-white);
    }

    .store-btn:hover {
        background: rgba(255,255,255,0.14);
        border-color: rgba(255,255,255,0.4);
        transform: translateY(-2px);
    }

    .store-btn-icon {
        width: 26px;
        height: 26px;
        flex-shrink: 0;
        fill: var(--color-white);
    }

    .store-btn-text { text-align: left; line-height: 1.2; }
    .store-btn-sub { font-size: 11px; font-weight: 400; opacity: 0.65; display: block; }
    .store-btn-name { font-size: 16px; font-weight: 700; display: block; font-family: 'Inter Tight', sans-serif; letter-spacing: -0.02em; }

    /* SECTION HEADERS */
    .section-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-fg-muted);
        margin-bottom: 14px;
        display: block;
    }

    .section-label-yellow { color: var(--color-accent-hover); }

    .section-heading {
        font-size: 48px;
        letter-spacing: -0.025em;
        margin-bottom: 16px;
        font-weight: 600;
    }

    .section-subtext {
        font-size: 18px;
        color: var(--color-fg-muted);
        max-width: 680px;
        line-height: 1.65;
    }

    .section-header {
        text-align: center;
        margin-bottom: 64px;
    }

    .section-header .section-subtext { margin: 0 auto; }

    /* FEATURES */
    .features-section { background: var(--color-white); }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .feature-card {
        background: var(--color-white);
        border: 1px solid var(--color-border-default);
        border-radius: 12px;
        padding: 36px 32px;
        transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
    }

    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
        border-color: var(--color-accent);
    }

    .feature-icon {
        width: 52px;
        height: 52px;
        background: rgba(250,204,21,0.1);
        border: 1px solid rgba(250,204,21,0.25);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    .feature-icon svg {
        width: 24px;
        height: 24px;
        stroke: var(--color-accent-hover);
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .feature-card h3 {
        font-size: 19px;
        margin-bottom: 10px;
        letter-spacing: -0.01em;
        font-weight: 600;
    }

    .feature-card p {
        font-size: 15px;
        line-height: 1.7;
        color: var(--color-fg-muted);
    }

    /* DOWNLOAD SECTION */
    .download-section {
        background: var(--color-black);
        color: var(--color-white);
        position: relative;
        overflow: hidden;
    }

    .download-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .download-section .section-label { color: rgba(255,255,255,0.5); }
    .download-section .section-heading { color: var(--color-white); }

    .download-platforms {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        position: relative;
        z-index: 1;
    }

    .download-card {
        padding: 52px 48px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
    }

    .download-card:hover {
        background: rgba(255,255,255,0.07);
        border-color: rgba(250,204,21,0.35);
        box-shadow: var(--shadow-yellow);
    }

    .platform-eyebrow {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
        margin-bottom: 12px;
        display: block;
    }

    .download-card h3 {
        font-size: 28px;
        font-weight: 600;
        color: var(--color-white);
        margin-bottom: 12px;
        letter-spacing: -0.02em;
    }

    .download-card p {
        font-size: 15px;
        line-height: 1.7;
        color: rgba(255,255,255,0.6);
        margin-bottom: 12px;
    }

    .platform-req {
        font-size: 13px;
        color: rgba(255,255,255,0.35);
        margin-bottom: 32px;
    }

    .store-btn-dark {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 14px 24px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.2s;
        cursor: pointer;
        background: var(--color-white);
        color: var(--color-black);
        border: 1px solid var(--color-white);
    }

    .store-btn-dark:hover {
        background: #f0f0f0;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(255,255,255,0.1);
    }

    .store-btn-dark-icon {
        width: 26px;
        height: 26px;
        fill: var(--color-black);
        flex-shrink: 0;
    }

    .store-btn-dark-text { text-align: left; line-height: 1.2; }
    .store-btn-dark-sub { font-size: 11px; font-weight: 400; color: var(--color-fg-muted); display: block; }
    .store-btn-dark-name { font-size: 16px; font-weight: 700; display: block; font-family: 'Inter Tight', sans-serif; letter-spacing: -0.02em; }

    /* SETUP STEPS */
    .setup-section {
        background: var(--color-black);
        color: var(--color-white);
        position: relative;
        overflow: hidden;
        border-top: 1px solid rgba(255,255,255,0.08);
    }

    .setup-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .setup-section .section-label { color: rgba(255,255,255,0.5); }
    .setup-section .section-heading { color: var(--color-white); }
    .setup-section .section-subtext { color: rgba(255,255,255,0.6); }

    .setup-steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2px;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        overflow: hidden;
        position: relative;
        z-index: 1;
    }

    .setup-step {
        padding: 48px 40px;
        background: rgba(255,255,255,0.03);
        border-right: 1px solid rgba(255,255,255,0.08);
        transition: background 0.3s;
    }

    .setup-step:last-child { border-right: none; }
    .setup-step:hover { background: rgba(255,255,255,0.06); }

    .setup-step-number {
        font-family: 'Inter Tight', sans-serif;
        font-size: 72px;
        font-weight: 900;
        color: rgba(250,204,21,0.12);
        line-height: 1;
        margin-bottom: 20px;
        letter-spacing: -0.04em;
    }

    .setup-step-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
        margin-bottom: 10px;
        display: block;
    }

    .setup-step h3 {
        font-size: 20px;
        color: var(--color-white);
        margin-bottom: 12px;
        font-weight: 600;
    }

    .setup-step p {
        font-size: 15px;
        line-height: 1.7;
        color: rgba(255,255,255,0.6);
    }

    /* STATS */
    .stats-section {
        background: var(--color-black);
        color: var(--color-white);
        position: relative;
        overflow: hidden;
    }

    .stats-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .stats-inner { position: relative; z-index: 1; }

    .stats-copy {
        text-align: center;
        max-width: 640px;
        margin: 0 auto 72px;
    }

    .stats-copy .section-label { color: rgba(255,255,255,0.5); display: block; text-align: center; }

    .stats-copy h2 {
        font-size: 44px;
        letter-spacing: -0.03em;
        color: var(--color-white);
        margin-bottom: 20px;
        font-weight: 600;
    }

    .stats-copy h2 .accent { color: var(--color-accent); }

    .stats-copy p {
        font-size: 18px;
        line-height: 1.65;
        color: rgba(255,255,255,0.65);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2px;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        overflow: hidden;
    }

    .stat-item {
        padding: 40px 32px;
        background: rgba(255,255,255,0.03);
        text-align: center;
        border-right: 1px solid rgba(255,255,255,0.08);
        transition: background 0.3s;
    }

    .stat-item:last-child { border-right: none; }
    .stat-item:hover { background: rgba(255,255,255,0.06); }

    .stat-number {
        font-family: 'Inter Tight', sans-serif;
        font-size: 44px;
        font-weight: 600;
        color: var(--color-accent);
        letter-spacing: -0.03em;
        margin-bottom: 8px;
        line-height: 1;
    }

    .stat-label {
        font-size: 14px;
        color: rgba(255,255,255,0.6);
        line-height: 1.4;
    }

    /* CTA SECTION */
    .cta-section { background: var(--color-canvas-subtle); }

    .cta-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 28px;
    }

    .cta-card {
        padding: 60px 56px;
        border-radius: 12px;
        text-align: center;
    }

    .cta-card-black {
        background: var(--color-black);
        color: var(--color-white);
        position: relative;
        overflow: hidden;
    }

    .cta-card-black::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .cta-card-white {
        background: var(--color-white);
        border: 1px solid var(--color-border-default);
    }

    .cta-card h3 {
        font-size: 30px;
        margin-bottom: 14px;
        position: relative;
        z-index: 1;
        letter-spacing: -0.02em;
    }

    .cta-card p {
        font-size: 16px;
        line-height: 1.65;
        margin-bottom: 32px;
        position: relative;
        z-index: 1;
    }

    .cta-card-black p { color: rgba(255,255,255,0.72); }
    .cta-card-white p { color: var(--color-fg-muted); }

    .cta-card .btn { position: relative; z-index: 1; }

    /* SUBSCRIPTION SECTION */
    .subscription-section { background: var(--color-white); }

    .subscription-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
        margin-bottom: 48px;
    }

    .subscription-card {
        background: var(--color-white);
        border: 1px solid var(--color-border-default);
        border-radius: 12px;
        padding: 40px 36px;
        transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
        position: relative;
    }

    .subscription-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
    }

    .subscription-card-featured {
        border: 2px solid var(--color-accent);
        box-shadow: var(--shadow-yellow);
        transform: scale(1.05);
    }

    .subscription-card-featured:hover {
        transform: scale(1.05) translateY(-4px);
        box-shadow: var(--shadow-yellow-lg);
    }

    .subscription-badge {
        display: inline-block;
        padding: 6px 12px;
        background: rgba(250,204,21,0.1);
        border: 1px solid rgba(250,204,21,0.3);
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent-hover);
        margin-bottom: 20px;
    }

    .subscription-badge-free {
        background: rgba(0,0,0,0.05);
        border-color: var(--color-border-default);
        color: var(--color-fg-muted);
    }

    .recommended-tag {
        position: absolute;
        top: -12px;
        right: 24px;
        background: var(--color-accent);
        color: var(--color-black);
        padding: 4px 12px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .subscription-card h3 {
        font-size: 24px;
        margin-bottom: 12px;
        letter-spacing: -0.02em;
        font-weight: 600;
    }

    .subscription-card .card-description {
        font-size: 15px;
        line-height: 1.7;
        color: var(--color-fg-muted);
        margin-bottom: 24px;
    }

    .subscription-features {
        list-style: none;
        margin-bottom: 24px;
    }

    .subscription-features li {
        font-size: 14px;
        line-height: 1.8;
        color: var(--color-fg-default);
        padding-left: 24px;
        position: relative;
        margin-bottom: 8px;
    }

    .subscription-features li:before {
        content: '✓';
        position: absolute;
        left: 0;
        color: var(--color-accent-hover);
        font-weight: 700;
    }

    .subscription-value {
        font-size: 15px;
        font-weight: 600;
        color: var(--color-fg-muted);
        font-style: italic;
        line-height: 1.6;
    }

    /* SOS ADD-ON BANNER */
    .sos-banner {
        display: flex;
        align-items: center;
        gap: 32px;
        background: var(--color-black);
        border-radius: 12px;
        padding: 40px 48px;
        margin-bottom: 80px;
        position: relative;
        overflow: hidden;
    }

    .sos-banner::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .sos-banner-icon {
        flex-shrink: 0;
        width: 64px;
        height: 64px;
        background: rgba(250,204,21,0.15);
        border: 2px solid var(--color-accent);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 1;
    }

    .sos-banner-icon svg {
        width: 32px;
        height: 32px;
        fill: var(--color-accent);
        stroke: none;
    }

    .sos-banner-content {
        flex: 1;
        position: relative;
        z-index: 1;
    }

    .sos-banner-content h3 {
        font-size: 28px;
        font-weight: 600;
        color: var(--color-white);
        margin-bottom: 8px;
        letter-spacing: -0.02em;
    }

    .sos-banner-price {
        font-size: 14px;
        font-weight: 600;
        color: var(--color-accent);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 12px;
    }

    .sos-banner-description {
        font-size: 15px;
        line-height: 1.7;
        color: rgba(255,255,255,0.75);
        max-width: 900px;
    }

    /* PRICING TABLE */
    .pricing-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .pricing-toggle-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0;
        margin: 0 auto 40px;
        width: 100%;
    }

    .pricing-toggle-wrapper > * {
        display: inline-flex;
        background: var(--color-canvas-subtle);
        border: 1px solid var(--color-border-default);
        border-radius: 8px;
        padding: 4px;
    }

    .pricing-tab {
        padding: 12px 28px;
        font-size: 15px;
        font-weight: 600;
        color: var(--color-fg-default);
        background: transparent;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
        white-space: nowrap;
        position: relative;
    }

    .pricing-tab:hover:not(.active) {
        background: rgba(0,0,0,0.04);
        transform: translateY(-1px);
    }

