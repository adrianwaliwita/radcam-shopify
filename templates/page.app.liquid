<script>
    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            const href = this.getAttribute('href');
            if (href === '#') return;
            e.preventDefault();
            const target = document.querySelector(href);
            if (target) {
                const top = target.getBoundingClientRect().top + window.pageYOffset - 80;
                window.scrollTo({ top, behavior: 'smooth' });
            }
        });
    });

    // Fade-up on scroll
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('fade-up');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.feature-card, .download-card, .setup-step, .stat-item, .cta-card, .subscription-card').forEach(el => {
        observer.observe(el);
    });

    // Pricing tab functionality
    const monthlyTab = document.getElementById('monthly-tab');
    const yearlyTab = document.getElementById('yearly-tab');

    function updatePricingDisplay(isYearly) {
        // Get all price cells
        const priceCells = document.querySelectorAll('.pricing-cell-price');
        const monthlyHeader = document.getElementById('pricing-header-monthly');
        const yearlyHeader = document.getElementById('pricing-header-yearly');

        // Fade out
        priceCells.forEach(cell => cell.style.opacity = '0');
        if (monthlyHeader) monthlyHeader.style.opacity = '0';
        if (yearlyHeader) yearlyHeader.style.opacity = '0';

        // Update content after fade out
        setTimeout(() => {
            // Update header
            if (isYearly) {
                monthlyHeader.style.display = 'none';
                yearlyHeader.style.display = 'flex';
            } else {
                monthlyHeader.style.display = 'flex';
                yearlyHeader.style.display = 'none';
            }

            // Update all pricing cells
            priceCells.forEach(cell => {
                const monthlyPrice = cell.getAttribute('data-monthly');
                const yearlyPrice = cell.getAttribute('data-yearly');

                if (monthlyPrice && yearlyPrice) {
                    cell.textContent = isYearly ? yearlyPrice : monthlyPrice;
                }
            });

            // Fade in
            setTimeout(() => {
                priceCells.forEach(cell => cell.style.opacity = '1');
                if (monthlyHeader) monthlyHeader.style.opacity = '1';
                if (yearlyHeader) yearlyHeader.style.opacity = '1';
            }, 50);
        }, 200);

        // Update active tab
        if (isYearly) {
            monthlyTab.classList.remove('active');
            yearlyTab.classList.add('active');
        } else {
            monthlyTab.classList.add('active');
            yearlyTab.classList.remove('active');
        }
    }

    if (monthlyTab && yearlyTab) {
        monthlyTab.addEventListener('click', function() {
            updatePricingDisplay(false);
        });

        yearlyTab.addEventListener('click', function() {
            updatePricingDisplay(true);
        });

        // Set default active state (monthly)
        updatePricingDisplay(false);
    }
</script>
