{% comment %}
  RADCam Product Page - Shopify Template
  This template integrates with your Shopify theme's header and footer
{% endcomment %}

<style>
    :root {
        --color-black: #000000;
        --color-white: #ffffff;
        --color-accent: #facc15;
        --color-accent-hover: #f5c400;
        --color-canvas-default: #ffffff;
        --color-canvas-subtle: #f6f8fa;
        --color-border-default: #d0d7de;
        --color-border-muted: #e1e4e8;
        --color-fg-default: #0d1117;
        --color-fg-muted: #57606a;
        --color-fg-subtle: #6e7781;
        --container-max: 1280px;
        --container-padding: 32px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24);
        --shadow-md: 0 14px 28px rgba(0,0,0,0.15), 0 10px 10px rgba(0,0,0,0.12);
        --shadow-lg: 0 24px 80px rgba(0,0,0,0.1);
        --shadow-yellow: 0 4px 16px rgba(250,204,21,0.3);
        --shadow-yellow-lg: 0 16px 40px rgba(250,204,21,0.35);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
        font-size: 16px;
        line-height: 1.6;
        color: var(--color-fg-default) !important;
        background: var(--color-white);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
        line-height: 1.15;
        font-weight: 500;
    }

    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; display: block; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; }

    .container {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 var(--container-padding);
    }

    .section { padding: 100px 0; }

    /* BUTTONS */
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 28px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        transition: all 0.2s;
        white-space: nowrap;
        cursor: pointer;
        width: 100%;
        font-family: 'Inter Tight', sans-serif;
        letter-spacing: -0.01em;
    }

    .btn-yellow {
        background: var(--color-accent);
        color: var(--color-black);
        border: 2px solid var(--color-accent);
    }

    .btn-yellow:hover {
        background: var(--color-accent-hover);
        transform: translateY(-1px);
        box-shadow: var(--shadow-yellow);
    }

    .btn-primary {
        background: var(--color-black);
        color: var(--color-white);
        border: 2px solid var(--color-black);
    }

    .btn-primary:hover {
        background: #1a1a1a;
        transform: translateY(-1px);
        box-shadow: var(--shadow-sm);
    }

    .btn-outline-white {
        background: transparent;
        color: var(--color-white);
        border: 2px solid rgba(255,255,255,0.4);
    }

    .btn-outline-white:hover {
        border-color: var(--color-white);
        background: rgba(255,255,255,0.08);
    }

    /* PRODUCT HERO */
    .product-hero {
        padding: 48px 0 80px;
        background: var(--color-white);
    }

    .product-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 72px;
        align-items: start;
    }

    /* Gallery */
    .gallery-main {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 16px;
        overflow: hidden;
        background: var(--color-canvas-subtle);
        margin-bottom: 14px;
        position: relative;
    }

    .gallery-main img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: opacity 0.25s ease;
    }

    .gallery-main img.fading { opacity: 0; }

    .gallery-thumbs {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 8px;
    }

    .gallery-thumb {
        aspect-ratio: 1;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        border: 2px solid transparent;
        transition: border-color 0.2s, opacity 0.2s;
        opacity: 0.6;
        background: var(--color-canvas-subtle);
    }

    .gallery-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .gallery-thumb:hover { opacity: 0.85; }

    .gallery-thumb.active {
        border-color: var(--color-accent);
        opacity: 1;
        box-shadow: var(--shadow-yellow);
    }

    /* Purchase Panel */
    .purchase-panel {
        position: sticky;
        top: 88px;
    }

    .ceo-quote {
        background: var(--color-canvas-subtle);
        border-left: 3px solid var(--color-accent);
        border-radius: 0 8px 8px 0;
        padding: 14px 18px;
        margin-bottom: 28px;
    }

    .ceo-quote p {
        font-size: 13px;
        line-height: 1.6;
        color: var(--color-fg-muted);
        font-style: italic;
        margin-bottom: 6px;
    }

    .ceo-quote cite {
        font-size: 12px;
        font-weight: 600;
        color: var(--color-fg-default);
        font-style: normal;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .product-title {
        font-size: 40px;
        letter-spacing: -0.035em;
        margin-bottom: 6px;
        color: var(--color-fg-default);
    }

    .product-subtitle {
        font-size: 15px;
        color: var(--color-fg-muted);
        margin-bottom: 20px;
        font-weight: 500;
    }

    .trust-badges {
        display: flex;
        gap: 20px;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }

    .trust-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--color-fg-muted);
    }

    .trust-badge svg {
        width: 16px;
        height: 16px;
        stroke: var(--color-accent-hover);
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        flex-shrink: 0;
    }

    /* Bundle Selector */
    .bundle-label {
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-fg-muted);
        margin-bottom: 12px;
    }

    .bundle-options {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 24px;
    }

    .bundle-option {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border: 2px solid var(--color-border-default);
        border-radius: 10px;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
        position: relative;
        background: var(--color-white);
        user-select: none;
    }

    .bundle-option:hover {
        border-color: var(--color-fg-muted);
    }

    .bundle-option.selected {
        border-color: var(--color-accent);
        background: rgba(250,204,21,0.04);
        box-shadow: var(--shadow-yellow);
    }

    .bundle-option-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .bundle-radio {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid var(--color-border-default);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: border-color 0.2s;
    }

    .bundle-option.selected .bundle-radio {
        border-color: var(--color-accent);
    }

    .bundle-radio-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--color-accent);
        opacity: 0;
        transition: opacity 0.2s, transform 0.2s;
        transform: scale(0.5);
    }

    .bundle-option.selected .bundle-radio-dot {
        opacity: 1;
        transform: scale(1);
    }

    .bundle-name {
        font-size: 15px;
        font-weight: 600;
        color: var(--color-fg-default);
    }

    .bundle-desc {
        font-size: 12px;
        color: var(--color-fg-muted);
        margin-top: 1px;
    }

    .bundle-option-right {
        text-align: right;
    }

    .bundle-price {
        font-family: 'Inter Tight', sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: var(--color-fg-default);
        letter-spacing: -0.02em;
    }

    .bundle-was {
        font-size: 13px;
        color: var(--color-fg-subtle);
        text-decoration: line-through;
    }

    .bundle-save-tag {
        position: absolute;
        top: -10px;
        right: 16px;
        background: var(--color-accent);
        color: var(--color-black);
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* Price Display */
    .price-display {
        display: flex;
        align-items: baseline;
        gap: 10px;
        margin-bottom: 20px;
    }

    .price-current {
        font-family: 'Inter Tight', sans-serif;
        font-size: 36px;
        font-weight: 600;
        color: var(--color-fg-default);
        letter-spacing: -0.03em;
    }

    .price-original {
        font-size: 18px;
        color: var(--color-fg-subtle);
        text-decoration: line-through;
    }

    .price-save-badge {
        background: rgba(250,204,21,0.15);
        color: var(--color-accent-hover);
        font-size: 13px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 4px;
    }

    /* CTA Buttons */
    .cta-stack {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 24px;
    }

    /* Quick features */
    .quick-features {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .quick-feature {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: var(--color-fg-muted);
    }

    .quick-feature svg {
        width: 16px;
        height: 16px;
        stroke: var(--color-accent-hover);
        fill: none;
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
        flex-shrink: 0;
    }

    /* COMPARISON TABLE (DARK) */
    .comparison-section {
        background: var(--color-black);
        color: var(--color-white);
        position: relative;
        overflow: hidden;
    }

    .comparison-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .comparison-section .section-label {
        color: rgba(255,255,255,0.5);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        display: block;
        text-align: center;
        margin-bottom: 14px;
    }

    .comparison-section .section-heading {
        font-size: 48px;
        letter-spacing: -0.025em;
        color: var(--color-white);
        text-align: center;
        margin-bottom: 16px;
    }

    .comparison-section .section-subtext {
        font-size: 17px;
        color: rgba(255,255,255,0.6);
        text-align: center;
        max-width: 600px;
        margin: 0 auto 60px;
        line-height: 1.65;
    }

    .comparison-table {
        position: relative;
        z-index: 1;
        max-width: 860px;
        margin: 0 auto;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        overflow: hidden;
    }

    .comparison-header {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        background: rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .comparison-header-cell {
        padding: 20px 28px;
        font-size: 15px;
        font-weight: 600;
        color: rgba(255,255,255,0.5);
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .comparison-header-cell.radcam-col {
        background: rgba(250,204,21,0.08);
        border-left: 1px solid rgba(250,204,21,0.2);
        border-right: 1px solid rgba(250,204,21,0.2);
        color: var(--color-accent);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .comparison-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        transition: background 0.2s;
    }

    .comparison-row:last-child { border-bottom: none; }

    .comparison-row:hover { background: rgba(255,255,255,0.02); }

    .comparison-cell {
        padding: 18px 28px;
        font-size: 15px;
        color: rgba(255,255,255,0.7);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .comparison-cell.feature-col {
        font-weight: 500;
        color: rgba(255,255,255,0.85);
    }

    .comparison-cell.radcam-col {
        background: rgba(250,204,21,0.04);
        border-left: 1px solid rgba(250,204,21,0.12);
        border-right: 1px solid rgba(250,204,21,0.12);
    }

    .check-icon {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: rgba(250,204,21,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .check-icon svg {
        width: 12px;
        height: 12px;
        stroke: var(--color-accent);
        fill: none;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .x-icon {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .x-icon svg {
        width: 10px;
        height: 10px;
        stroke: rgba(255,255,255,0.25);
        fill: none;
        stroke-width: 2.5;
        stroke-linecap: round;
    }

    /* FEATURE CALLOUTS */
    .callouts-section {
        background: var(--color-canvas-subtle);
    }

    .callout-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
        margin-bottom: 100px;
    }

    .callout-row:last-child { margin-bottom: 0; }

    .callout-row.reverse { direction: rtl; }
    .callout-row.reverse > * { direction: ltr; }

    .callout-visual {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        aspect-ratio: 1;
        background: var(--color-border-muted);
    }

    .callout-visual img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .callout-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent-hover);
        margin-bottom: 14px;
        display: block;
    }

    .callout-content h2 {
        font-size: 38px;
        letter-spacing: -0.025em;
        margin-bottom: 18px;
    }

    .callout-content p {
        font-size: 16px;
        line-height: 1.75;
        color: var(--color-fg-muted);
        margin-bottom: 16px;
    }

    .callout-content p:last-of-type { margin-bottom: 24px; }

    .callout-bullets {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .callout-bullet {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        font-size: 15px;
        color: var(--color-fg-muted);
    }

    .callout-bullet-dot {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--color-accent);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .callout-bullet-dot svg {
        width: 10px;
        height: 10px;
        stroke: var(--color-black);
        fill: none;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    /* SPECS ACCORDION */
    .specs-section {
        background: var(--color-white);
    }

    .specs-inner {
        max-width: 900px;
        margin: 0 auto;
    }

    .specs-section .section-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent-hover);
        display: block;
        text-align: center;
        margin-bottom: 14px;
    }

    .specs-section .section-heading {
        font-size: 44px;
        letter-spacing: -0.025em;
        text-align: center;
        margin-bottom: 56px;
    }

    .spec-accordion-item {
        border-bottom: 1px solid var(--color-border-default);
    }

    .spec-accordion-item:first-child {
        border-top: 1px solid var(--color-border-default);
    }

    .spec-accordion-header {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 0;
        text-align: left;
        cursor: pointer;
        background: none;
        transition: background 0.15s;
    }

    .spec-accordion-header:hover { background: rgba(0,0,0,0.01); }

    .spec-accordion-title {
        font-size: 18px;
        font-weight: 600;
        color: var(--color-fg-default);
        font-family: 'Inter Tight', sans-serif;
    }

    .spec-accordion-toggle {
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: var(--color-canvas-subtle);
        border: 1px solid var(--color-border-default);
        font-size: 18px;
        color: var(--color-fg-muted);
        transition: transform 0.3s, background 0.2s, border-color 0.2s;
        flex-shrink: 0;
    }

    .spec-accordion-item.active .spec-accordion-toggle {
        transform: rotate(45deg);
        background: var(--color-accent);
        border-color: var(--color-accent);
        color: var(--color-black);
    }

    .spec-accordion-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s ease;
    }

    .spec-accordion-inner {
        padding: 0 0 28px 0;
    }

    .spec-accordion-inner p {
        font-size: 15px;
        line-height: 1.75;
        color: var(--color-fg-muted);
        margin-bottom: 14px;
    }

    .spec-accordion-inner p:last-child { margin-bottom: 0; }

    .spec-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border: 1px solid var(--color-border-default);
        border-radius: 8px;
        overflow: hidden;
    }

    .spec-row {
        display: contents;
    }

    .spec-key {
        padding: 12px 18px;
        font-size: 13px;
        font-weight: 600;
        color: var(--color-fg-default);
        background: var(--color-canvas-subtle);
        border-bottom: 1px solid var(--color-border-default);
        border-right: 1px solid var(--color-border-default);
    }

    .spec-val {
        padding: 12px 18px;
        font-size: 13px;
        color: var(--color-fg-muted);
        background: var(--color-white);
        border-bottom: 1px solid var(--color-border-default);
    }

    .spec-row:last-child .spec-key,
    .spec-row:last-child .spec-val {
        border-bottom: none;
    }

    .sub-plan-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 8px;
    }

    .sub-plan-card {
        border: 1px solid var(--color-border-default);
        border-radius: 8px;
        padding: 20px;
    }

    .sub-plan-name {
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-fg-muted);
        margin-bottom: 10px;
    }

    .sub-plan-tier {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid var(--color-border-muted);
        font-size: 14px;
    }

    .sub-plan-tier:last-child { border-bottom: none; }

    .sub-plan-tier-name { color: var(--color-fg-default); font-weight: 500; }
    .sub-plan-tier-price { color: var(--color-fg-muted); font-weight: 600; }

    .sub-note {
        font-size: 13px;
        color: var(--color-fg-muted);
        margin-top: 16px;
        padding: 12px 16px;
        background: var(--color-canvas-subtle);
        border-radius: 6px;
        border-left: 3px solid var(--color-accent);
    }

    /* TESTIMONIALS */
    .testimonials-section {
        background: var(--color-canvas-subtle);
    }

    .testimonials-section .section-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent-hover);
        display: block;
        text-align: center;
        margin-bottom: 14px;
    }

    .testimonials-section .section-heading {
        font-size: 44px;
        letter-spacing: -0.025em;
        text-align: center;
        margin-bottom: 56px;
    }

    .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
    }

    .testimonial-card {
        background: var(--color-white);
        border: 1px solid var(--color-border-default);
        border-radius: 12px;
        padding: 36px 32px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .testimonial-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }

    .testimonial-stars {
        display: flex;
        gap: 3px;
        margin-bottom: 18px;
    }

    .star {
        width: 18px;
        height: 18px;
        fill: var(--color-accent);
    }

    .testimonial-quote {
        font-size: 16px;
        line-height: 1.7;
        color: var(--color-fg-default);
        margin-bottom: 24px;
        font-style: italic;
    }

    .testimonial-author {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .testimonial-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--color-accent);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 600;
        color: var(--color-black);
        font-family: 'Inter Tight', sans-serif;
        flex-shrink: 0;
    }

    .testimonial-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--color-fg-default);
    }

    .testimonial-verified {
        font-size: 12px;
        color: var(--color-accent-hover);
        font-weight: 600;
    }

    /* FINAL CTA */
    .final-cta {
        background: var(--color-black);
        color: var(--color-white);
        position: relative;
        overflow: hidden;
        text-align: center;
    }

    .final-cta::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .final-cta-inner {
        position: relative;
        z-index: 1;
        max-width: 680px;
        margin: 0 auto;
    }

    .final-cta h2 {
        font-size: 50px;
        letter-spacing: -0.03em;
        margin-bottom: 18px;
        color: var(--color-white);
    }

    .final-cta h2 .accent { color: var(--color-accent); }

    .final-cta p {
        font-size: 18px;
        line-height: 1.65;
        color: rgba(255,255,255,0.68);
        margin-bottom: 36px;
    }

    .final-cta-buttons {
        display: flex;
        gap: 14px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .final-cta-buttons .btn {
        width: auto;
        padding: 15px 36px;
    }

    /* ANIMATIONS */
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(14px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .fade-up { animation: fadeUp 0.45s ease forwards; }

    /* Responsive */
    @media (max-width: 1024px) {
        :root { --container-padding: 24px; }
        .product-grid { grid-template-columns: 1fr; gap: 48px; }
        .purchase-panel { position: relative; top: 0; }
        .gallery-thumbs { grid-template-columns: repeat(7, 1fr); }
        .callout-row { grid-template-columns: 1fr; gap: 40px; }
        .callout-row.reverse { direction: ltr; }
        .sub-plan-grid { grid-template-columns: 1fr; }
        .testimonials-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 768px) {
        .section { padding: 72px 0; }
        .product-title { font-size: 32px; }
        .comparison-section .section-heading { font-size: 30px; }
        .comparison-header-cell { padding: 14px 16px; font-size: 12px; }
        .comparison-cell { padding: 14px 16px; font-size: 13px; }
        .gallery-thumbs { grid-template-columns: repeat(4, 1fr); }
        .bundle-options { gap: 8px; }
        .callout-content h2 { font-size: 30px; }
        .specs-section .section-heading,
        .testimonials-section .section-heading { font-size: 32px; }
        .spec-grid { grid-template-columns: 1fr; }
        .spec-key { border-right: none; border-bottom: none; }
        .spec-val { border-bottom: 1px solid var(--color-border-default); }
        .final-cta h2 { font-size: 34px; }
    }

    @media (max-width: 480px) {
        .trust-badges { gap: 12px; }
        .gallery-thumbs { grid-template-columns: repeat(4, 1fr); }
        .comparison-cell.feature-col { font-size: 12px; }
    }
</style>

