                    <li class="quick-feature">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                        IP66-rated, indoor &amp; outdoor, all weather
                    </li>
                    <li class="quick-feature">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                        Subscription activated after setup, not before
                    </li>
                </ul>

            </div>
        </div>
    </div>
</section>

