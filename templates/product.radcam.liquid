                <h1 class="product-title">{{ product.title }}</h1>
                <p class="product-subtitle">The World's First Talking Camera · Powered by AIR™</p>

                <div class="trust-badges">
                    <div class="trust-badge">
                        <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        Free US Shipping
                    </div>
                    <div class="trust-badge">
                        <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        Money-Back Guarantee
                    </div>
                    <div class="trust-badge">
                        <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
                        Easy Returns
                    </div>
                </div>

                <div class="bundle-label">SELECT PACKAGE</div>
                <div class="bundle-options">
                    {% for variant in product.variants %}
                        <div class="bundle-option {% if variant == product.selected_or_first_available_variant %}selected{% endif %}" data-variant-id="{{ variant.id }}" data-price="{{ variant.price | money_without_currency }}" data-price-formatted="{{ variant.price | money }}" {% if variant.compare_at_price %}data-was="{{ variant.compare_at_price | money }}"{% endif %} onclick="selectVariant(this, {{ variant.id }})">
                            {% assign option_check = variant.option1 | default: variant.title %}
                            {% if option_check contains "3-Pack" or option_check contains "3 Pack" or option_check contains "3" or forloop.index == 3 %}
                                <span class="bundle-save-tag">Best Value</span>
                            {% endif %}
                            <div class="bundle-option-left">
                                <div class="bundle-radio">
                                    <div class="bundle-radio-dot"></div>
                                </div>
                                <div>
                                    <div class="bundle-name">
                                        {% if variant.option1 != "Default Title" and variant.option1 != blank %}
                                            {{ variant.option1 }}
                                        {% elsif variant.title != "Default Title" %}
                                            {{ variant.title }}
                                        {% else %}
                                            {% assign variant_index = forloop.index %}
                                            {% if variant_index == 1 %}
                                                Single RADCam
                                            {% elsif variant_index == 2 %}
                                                2-Pack RADCam
                                            {% elsif variant_index == 3 %}
                                                3-Pack RADCam
                                            {% else %}
                                                Package {{ variant_index }}
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                    <div class="bundle-desc">
                                        {% assign option_name = variant.option1 | default: variant.title %}
                                        {% if option_name contains "Single" or option_name contains "1" or forloop.index == 1 %}
                                            1x RADCam™ device
                                        {% elsif option_name contains "2-Pack" or option_name contains "2 Pack" or option_name contains "2" or forloop.index == 2 %}
                                            2x RADCam™, front and back
                                        {% elsif option_name contains "3-Pack" or option_name contains "3 Pack" or option_name contains "3" or forloop.index == 3 %}
                                            Full home coverage, most popular
                                        {% else %}
                                            Premium package
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="bundle-option-right">
                                <div class="bundle-price">{{ variant.price | money }}</div>
                                {% if variant.compare_at_price > variant.price %}
                                    <div class="bundle-was">{{ variant.compare_at_price | money }}</div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="price-display">
                    <span class="price-current" id="priceDisplay">{{ product.selected_or_first_available_variant.price | money }}</span>
                    {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
                        <span class="price-original" id="priceWas">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
                        <span class="price-save-badge" id="priceSave">Save {{ product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100 | divided_by: product.selected_or_first_available_variant.compare_at_price }}%</span>
                    {% endif %}
                </div>

                <div class="cta-stack">
                    {% form 'product', product %}
                        <input type="hidden" name="id" id="variantId" value="{{ product.selected_or_first_available_variant.id }}">
                        <button type="submit" name="add" class="btn btn-yellow">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                            Add to Cart
                        </button>
                    {% endform %}
                </div>

                <ul class="quick-features">
                    <li class="quick-feature">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                        AI talks back, greets visitors, warns intruders, in real time
