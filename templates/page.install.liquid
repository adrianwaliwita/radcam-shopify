{% comment %}
  RADCam Installation Guide Page - Shopify Template
  This template integrates with your Shopify theme's header and footer
{% endcomment %}

{% assign radcam_product = all_products['radcam-the-talking-camera-pre-order-now'] %}

<style>
    :root {
        --color-black: #000000;
        --color-white: #ffffff;
        --color-accent: #facc15;
        --color-accent-hover: #f5c400;
        --color-canvas-default: #ffffff;
        --color-canvas-subtle: #f6f8fa;
        --color-border-default: #d0d7de;
        --color-border-muted: #e1e4e8;
        --color-fg-default: #0d1117;
        --color-fg-muted: #57606a;
        --color-fg-subtle: #6e7781;
        --container-max: 1280px;
        --container-padding: 32px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24);
        --shadow-md: 0 14px 28px rgba(0,0,0,0.15), 0 10px 10px rgba(0,0,0,0.12);
        --shadow-lg: 0 24px 80px rgba(0,0,0,0.1);
        --shadow-yellow: 0 4px 12px rgba(250,204,21,0.25);
        --shadow-yellow-lg: 0 16px 40px rgba(250,204,21,0.35);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
        font-size: 17px;
        line-height: 1.6;
        color: var(--color-fg-default) !important;
        background: var(--color-white);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
        line-height: 1.15;
        font-weight: 500;
    }

    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; display: block; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; }

    .rc-container {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 var(--container-padding);
    }

    .rc-section { padding: 120px 0; }

    /* BUTTONS */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 22px;
        border-radius: 6px;
        font-size: 15px;
        font-weight: 600;
        transition: all 0.2s;
        white-space: nowrap;
        cursor: pointer;
    }

    .btn-yellow {
        background: var(--color-accent);
        color: var(--color-black);
        border: 1px solid var(--color-accent);
    }

    .btn-yellow:hover {
        background: var(--color-accent-hover);
        transform: translateY(-1px);
        box-shadow: var(--shadow-yellow);
    }

    .btn-primary {
        background: var(--color-black);
        color: var(--color-white);
        border: 1px solid var(--color-black);
    }

    .btn-primary:hover {
        background: #1a1a1a;
        transform: translateY(-1px);
        box-shadow: var(--shadow-sm);
    }

    .btn-outline-white {
        background: transparent;
        color: var(--color-white);
        border: 1px solid rgba(255,255,255,0.4);
    }

    .btn-outline-white:hover {
        border-color: var(--color-white);
        background: rgba(255,255,255,0.08);
    }

    .btn-lg { padding: 14px 32px; font-size: 16px; }

    /* PAGE HERO */
    .install-hero {
        background: var(--color-black);
        color: var(--color-white);
        padding: 100px 0 80px;
        position: relative;
        overflow: hidden;
    }

    .install-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .install-hero-inner {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    .install-hero-badge {
        display: inline-block;
        padding: 6px 14px;
        background: rgba(250,204,21,0.12);
        border: 1px solid var(--color-accent);
        border-radius: 4px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
        margin-bottom: 24px;
    }

    .install-hero h1 {
        font-size: 56px;
        letter-spacing: -0.04em;
        margin-bottom: 20px;
        line-height: 1.05;
        color: var(--color-white) !important;
        font-weight: 600;
    }

    .install-hero h1 .accent { color: var(--color-accent) !important; }

    .install-hero-description {
        font-size: 18px;
        line-height: 1.65;
        color: rgba(255,255,255,0.7);
        margin-bottom: 36px;
    }

    .install-hero-steps {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }

    .install-hero-step-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: rgba(255,255,255,0.55);
    }

    .install-hero-step-pill span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        background: var(--color-accent);
        color: var(--color-black);
        border-radius: 50%;
        font-size: 11px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .install-hero-visual {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .install-hero-img {
        width: 100%;
        aspect-ratio: 1;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.06);
    }

    /* STICKY TOC */
    .install-toc-bar {
        background: var(--color-canvas-subtle);
        border-bottom: 1px solid var(--color-border-default);
        padding: 0;
        position: sticky;
        top: 0;
        z-index: 90;
    }

    .install-toc-inner {
        display: flex;
        gap: 0;
        overflow-x: auto;
        scrollbar-width: none;
    }

    .install-toc-inner::-webkit-scrollbar { display: none; }

    .install-toc-link {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 16px 24px;
        font-size: 14px;
        font-weight: 500;
        color: var(--color-fg-muted);
        border-bottom: 2px solid transparent;
        transition: color 0.2s, border-color 0.2s;
        white-space: nowrap;
    }

    .install-toc-link:hover { color: var(--color-fg-default); border-bottom-color: var(--color-border-default); }
    .install-toc-link.active { color: var(--color-fg-default); border-bottom-color: var(--color-accent); }

    .install-toc-num {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
        background: var(--color-accent);
        color: var(--color-black);
        border-radius: 50%;
        font-size: 11px;
        font-weight: 700;
    }

    /* SECTION LABELS & HEADINGS */
    .section-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-fg-muted);
        margin-bottom: 14px;
        display: block;
    }

    .section-label-yellow { color: var(--color-accent-hover); }

    .section-heading {
        font-size: 48px;
        letter-spacing: -0.025em;
        margin-bottom: 16px;
        font-weight: 600;
    }

    .section-subtext {
        font-size: 18px;
        color: var(--color-fg-muted);
        max-width: 680px;
        line-height: 1.65;
    }

    .section-header {
        text-align: center;
        margin-bottom: 64px;
    }

    .section-header .section-subtext { margin: 0 auto; }

    /* OVERVIEW */
    .overview-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
    }

    .overview-content h2 {
        font-size: 40px;
        letter-spacing: -0.025em;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .overview-content p {
        font-size: 17px;
        line-height: 1.75;
        color: var(--color-fg-muted);
        margin-bottom: 32px;
    }

    .location-list { list-style: none; margin-bottom: 36px; }

    .location-item {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid var(--color-border-muted);
    }

    .location-item:first-child { border-top: 1px solid var(--color-border-muted); }

    .location-icon {
        width: 36px;
        height: 36px;
        background: rgba(250,204,21,0.12);
        border: 1px solid rgba(250,204,21,0.3);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .location-icon svg {
        width: 18px;
        height: 18px;
        stroke: var(--color-accent-hover);
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .location-text strong {
        display: block;
        font-size: 15px;
        font-weight: 600;
        color: var(--color-fg-default);
        margin-bottom: 2px;
    }

    .location-text span { font-size: 14px; color: var(--color-fg-muted); }

    .height-callout {
        background: var(--color-canvas-subtle);
        border: 1px solid var(--color-border-default);
        border-radius: 10px;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .height-callout-icon {
        width: 44px;
        height: 44px;
        background: var(--color-accent);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .height-callout-icon svg {
        width: 22px;
        height: 22px;
        stroke: var(--color-black);
        fill: none;
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .height-callout-text strong {
        display: block;
        font-size: 15px;
        font-weight: 600;
        color: var(--color-fg-default);
    }

    .height-callout-text span { font-size: 14px; color: var(--color-fg-muted); }

    .whats-included {
        background: var(--color-canvas-subtle);
        border: 1px solid var(--color-border-default);
        border-radius: 16px;
        padding: 40px;
    }

    .whats-included h3 { font-size: 22px; margin-bottom: 24px; }

    .included-list { list-style: none; }

    .included-list li {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--color-border-muted);
        font-size: 15px;
        color: var(--color-fg-muted);
    }

    .included-list li:last-child { border-bottom: none; }

    .check-dot {
        width: 20px;
        height: 20px;
        background: var(--color-accent);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .check-dot svg {
        width: 10px;
        height: 10px;
        stroke: var(--color-black);
        fill: none;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    /* INSTALLATION STEPS */
    .steps-section { background: var(--color-canvas-subtle); }

    .steps-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 56px;
        align-items: start;
    }

    .steps-sidebar {
        position: sticky;
        top: 80px;
    }

    .steps-nav { list-style: none; }
    .steps-nav li { margin-bottom: 4px; }

    .steps-nav-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        color: var(--color-fg-muted);
        transition: all 0.2s;
        cursor: pointer;
    }

    .steps-nav-link:hover { background: rgba(0,0,0,0.04); color: var(--color-fg-default); }
    .steps-nav-link.active { background: var(--color-white); color: var(--color-fg-default); box-shadow: var(--shadow-sm); }

    .steps-nav-num {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: var(--color-border-default);
        color: var(--color-fg-muted);
        font-size: 12px;
        font-weight: 700;
        flex-shrink: 0;
        transition: background 0.2s, color 0.2s;
    }

    .steps-nav-link.active .steps-nav-num { background: var(--color-accent); color: var(--color-black); }

    .steps-tools {
        margin-top: 32px;
        background: var(--color-white);
        border: 1px solid var(--color-border-default);
        border-radius: 10px;
        padding: 24px;
    }

    .steps-tools h4 { font-size: 14px; font-weight: 600; margin-bottom: 16px; color: var(--color-fg-default); }
    .steps-tools ul { list-style: none; }

    .steps-tools ul li {
        font-size: 13px;
        color: var(--color-fg-muted);
        padding: 6px 0;
        padding-left: 16px;
        position: relative;
        border-bottom: 1px solid var(--color-border-muted);
    }

    .steps-tools ul li:last-child { border-bottom: none; }
    .steps-tools ul li::before { content: '•'; position: absolute; left: 0; color: var(--color-accent-hover); font-size: 11px; }

    /* Step Cards */
    .step-card {
        background: var(--color-white);
        border: 1px solid var(--color-border-default);
        border-radius: 16px;
        padding: 44px;
        margin-bottom: 24px;
        transition: border-color 0.3s;
    }

    .step-card:last-child { margin-bottom: 0; }
    .step-card:hover { border-color: var(--color-accent); }

    .step-card-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 28px;
    }

    .step-number-large {
        font-family: 'Inter Tight', sans-serif;
        font-size: 64px;
        font-weight: 900;
        color: rgba(250,204,21,0.15);
        line-height: 1;
        letter-spacing: -0.04em;
        flex-shrink: 0;
        min-width: 72px;
    }

    .step-card-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent-hover);
        margin-bottom: 6px;
        display: block;
    }

    .step-card h3 { font-size: 26px; letter-spacing: -0.02em; }

    .step-content p {
        font-size: 16px;
        line-height: 1.75;
        color: var(--color-fg-muted);
        margin-bottom: 20px;
    }

    .step-content p:last-child { margin-bottom: 0; }

    .step-substeps { list-style: none; margin-top: 20px; }

    .step-substep {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid var(--color-border-muted);
    }

    .step-substep:last-child { border-bottom: none; }

    .step-substep-num {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: var(--color-canvas-subtle);
        border: 1px solid var(--color-border-default);
        font-size: 12px;
        font-weight: 700;
        color: var(--color-fg-muted);
        flex-shrink: 0;
        margin-top: 1px;
    }

    .step-substep-text { font-size: 15px; color: var(--color-fg-muted); line-height: 1.6; }
    .step-substep-text strong { color: var(--color-fg-default); }

    .surface-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-top: 20px;
    }

    .surface-card {
        background: var(--color-canvas-subtle);
        border: 1px solid var(--color-border-default);
        border-radius: 8px;
        padding: 16px;
    }

    .surface-card strong { display: block; font-size: 13px; font-weight: 600; color: var(--color-fg-default); margin-bottom: 6px; }
    .surface-card p { font-size: 13px; line-height: 1.5; color: var(--color-fg-muted); margin-bottom: 0 !important; }

    .tip-box {
        background: rgba(250,204,21,0.07);
        border: 1px solid rgba(250,204,21,0.3);
        border-radius: 8px;
        padding: 16px 20px;
        margin-top: 20px;
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .tip-box-icon { font-size: 16px; flex-shrink: 0; margin-top: 2px; }

    .tip-box p { font-size: 14px; color: var(--color-fg-muted); margin-bottom: 0 !important; }
    .tip-box p strong { color: var(--color-fg-default); }

    /* MODES */
    .modes-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .mode-card {
        border: 1px solid var(--color-border-default);
        border-radius: 14px;
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
    }

    .mode-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
        border-color: var(--color-accent);
    }

    .mode-card-header { padding: 28px 28px 20px; border-bottom: 1px solid var(--color-border-muted); }

    .mode-card-icon {
        width: 48px;
        height: 48px;
        background: rgba(250,204,21,0.1);
        border: 1px solid rgba(250,204,21,0.25);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    .mode-card-icon svg {
        width: 24px;
        height: 24px;
        stroke: var(--color-accent-hover);
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .mode-card h3 { font-size: 20px; margin-bottom: 6px; }

    .mode-card-tag {
        display: inline-block;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 2px 8px;
        border-radius: 4px;
        background: rgba(250,204,21,0.12);
        color: var(--color-accent-hover);
    }

    .mode-card-body { padding: 24px 28px 28px; }

    .mode-card-body p {
        font-size: 15px;
        line-height: 1.7;
        color: var(--color-fg-muted);
        margin-bottom: 16px;
    }

    .mode-features { list-style: none; }

    .mode-features li {
        font-size: 14px;
        color: var(--color-fg-muted);
        padding: 8px 0;
        border-bottom: 1px solid var(--color-border-muted);
        padding-left: 20px;
        position: relative;
    }

    .mode-features li:last-child { border-bottom: none; }
    .mode-features li::before { content: '→'; position: absolute; left: 0; color: var(--color-accent-hover); font-size: 12px; }

    /* Scheduling block */
    .schedule-block {
        background: var(--color-black);
        border-radius: 16px;
        padding: 56px;
        margin-top: 56px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

    .schedule-block::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
    }

    .schedule-block-text { position: relative; z-index: 1; }

    .schedule-block-text h3 {
        font-size: 32px;
        color: var(--color-white);
        margin-bottom: 16px;
        letter-spacing: -0.02em;
    }

    .schedule-block-text p { font-size: 16px; line-height: 1.7; color: rgba(255,255,255,0.65); }

    .schedule-visual { position: relative; z-index: 1; }

    .schedule-days {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 6px;
        margin-bottom: 16px;
    }

    .schedule-day {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 6px;
        padding: 8px 4px;
        text-align: center;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        letter-spacing: 0.04em;
    }

    .schedule-day.highlight { background: rgba(250,204,21,0.12); border-color: rgba(250,204,21,0.3); color: var(--color-accent); }

    .schedule-slots { display: flex; flex-direction: column; gap: 6px; }

    .schedule-slot {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 6px;
        padding: 10px 14px;
    }

    .schedule-slot-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .schedule-slot-dot.concierge { background: var(--color-accent); }
    .schedule-slot-dot.security { background: #f87171; }
    .schedule-slot-dot.quiet { background: #60a5fa; }
    .schedule-slot-label { font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.7); flex: 1; }
    .schedule-slot-time { font-size: 12px; color: rgba(255,255,255,0.4); }

    /* MAINTENANCE */
    .maintenance-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 32px;
    }

    .maintenance-card {
        background: var(--color-white);
        border: 1px solid var(--color-border-default);
        border-radius: 14px;
        padding: 36px;
    }

    .maintenance-card-icon {
        width: 48px;
        height: 48px;
        background: rgba(250,204,21,0.1);
        border: 1px solid rgba(250,204,21,0.25);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    .maintenance-card-icon svg {
        width: 24px;
        height: 24px;
        stroke: var(--color-accent-hover);
        fill: none;
