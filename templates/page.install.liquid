<script>
    // Sticky TOC active state on scroll
    const installSections = document.querySelectorAll('#install-overview, #install-steps, #install-modes, #install-maintenance');
    const installTocLinks = document.querySelectorAll('.install-toc-link');

    const tocObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const id = entry.target.getAttribute('id');
                installTocLinks.forEach(link => {
                    link.classList.toggle('active', link.getAttribute('href') === '#' + id);
                });
            }
        });
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    installSections.forEach(s => tocObserver.observe(s));

    // Step sidebar active state
    const stepCards = document.querySelectorAll('#install-step1, #install-step2, #install-step3, #install-step4, #install-step5, #install-step6');
    const stepNavLinks = document.querySelectorAll('.steps-nav-link');

    const stepObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const id = entry.target.getAttribute('id');
                stepNavLinks.forEach(link => {
                    link.classList.toggle('active', link.getAttribute('href') === '#' + id);
                });
            }
        });
    }, { rootMargin: '-80px 0px -55% 0px', threshold: 0 });

    stepCards.forEach(s => stepObserver.observe(s));

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            const href = this.getAttribute('href');
            if (href === '#') return;
            e.preventDefault();
            const target = document.querySelector(href);
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });

    // Fade-up on scroll
    const fadeObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('fade-up');
                fadeObserver.unobserve(entry.target);
            }
        });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.step-card, .mode-card, .maintenance-card, .location-item').forEach(el => {
        fadeObserver.observe(el);
    });
</script>
