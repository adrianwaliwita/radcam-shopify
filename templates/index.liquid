{% comment %}
  RADCam Home Page - Shopify Template
  This template integrates with your Shopify theme's header and footer
{% endcomment %}

<style>
    :root {
        --color-black: #000000;
        --color-white: #ffffff;
        --color-accent: #facc15;
        --color-accent-hover: #f5c400;
        --color-canvas-default: #ffffff;
        --color-canvas-subtle: #f6f8fa;
        --color-border-default: #d0d7de;
        --color-border-muted: #e1e4e8;
        --color-fg-default: #0d1117;
        --color-fg-muted: #57606a;
        --color-fg-subtle: #6e7781;
        --container-max: 1280px;
        --container-padding: 32px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24);
        --shadow-md: 0 14px 28px rgba(0,0,0,0.15), 0 10px 10px rgba(0,0,0,0.12);
        --shadow-lg: 0 24px 80px rgba(0,0,0,0.1);
        --shadow-yellow: 0 4px 12px rgba(250,204,21,0.25);
        --shadow-yellow-lg: 0 16px 40px rgba(250,204,21,0.35);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-size: 17px;
        line-height: 1.6;
        color: var(--color-fg-default);
        background: var(--color-white);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.15;
        font-weight: 500;
    }

    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; display: block; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; }

    .container {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 var(--container-padding);
    }

    .section { padding: 120px 0; }
    .section-sm { padding: 80px 0; }

    /* ===========================
       BUTTONS
       =========================== */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 22px;
        border-radius: 6px;
        font-size: 15px;
        font-weight: 600;
        transition: all 0.2s;
        white-space: nowrap;
        cursor: pointer;
    }

    .btn-yellow {
        background: var(--color-accent);
        color: var(--color-black);
        border: 1px solid var(--color-accent);
    }

    .btn-yellow:hover {
        background: var(--color-accent-hover);
        transform: translateY(-1px);
        box-shadow: var(--shadow-yellow);
    }

    .btn-primary {
        background: var(--color-black);
        color: var(--color-white);
        border: 1px solid var(--color-black);
    }

    .btn-primary:hover {
        background: #1a1a1a;
        transform: translateY(-1px);
        box-shadow: var(--shadow-sm);
    }

    .btn-outline-white {
        background: transparent;
        color: var(--color-white);
        border: 1px solid rgba(255,255,255,0.4);
    }

    .btn-outline-white:hover {
        border-color: var(--color-white);
        background: rgba(255,255,255,0.08);
    }

    .btn-secondary {
        background: transparent;
        color: var(--color-fg-default);
        border: 1px solid var(--color-border-default);
    }

    .btn-secondary:hover {
        background: var(--color-canvas-subtle);
        border-color: var(--color-fg-muted);
    }

    .btn-lg { padding: 14px 32px; font-size: 16px; }
    .btn-xl { padding: 17px 40px; font-size: 17px; }

    /* ===========================
       HERO
       =========================== */
    .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        background: var(--color-black);
        color: var(--color-white);
        overflow: hidden;
    }

    .hero::before {
        display: none;
    }

    .hero-bg-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.18;
        z-index: 0;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
        padding: 100px 0;
        width: 100%;
    }

    .hero-text { }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        background: rgba(250,204,21,0.12);
        border: 1px solid var(--color-accent);
        border-radius: 4px;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
        margin-bottom: 28px;
    }

    .hero-badge-dot {
        width: 5px;
        height: 5px;
        background: var(--color-accent);
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }

    .hero h1 {
        font-size: 68px;
        letter-spacing: -0.04em;
        margin-bottom: 24px;
        line-height: 1.05;
        color: var(--color-white) !important;
    }

    .hero h1 .accent {
        color: var(--color-accent) !important;
    }

    .hero-description {
        font-size: 19px;
        line-height: 1.65;
        color: rgba(255,255,255,0.75);
        margin-bottom: 40px;
        max-width: 520px;
    }

    .hero-buttons {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 48px;
    }

    .hero-trust {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .hero-trust-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: rgba(255,255,255,0.55);
    }

    .hero-trust-item svg {
        width: 16px;
        height: 16px;
        stroke: var(--color-accent);
        fill: none;
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
        flex-shrink: 0;
    }

    .hero-visual {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .hero-product-wrap {
        position: relative;
        width: 100%;
        max-width: 480px;
        margin: 0 auto;
    }

    .hero-product-glow {
        position: absolute;
        inset: -40px;
        background: radial-gradient(ellipse at center, rgba(250,204,21,0.12) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero-product-img {
        width: 100%;
        aspect-ratio: 1;
        object-fit: cover;
        border-radius: 16px;
        position: relative;
        z-index: 1;
        box-shadow: 0 40px 100px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.06);
    }

    .hero-video-controls {
        position: absolute;
        bottom: 20px;
        right: 20px;
        display: flex;
        gap: 12px;
        z-index: 2;
    }

    .hero-video-btn {
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        padding: 12px;
        color: white;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
    }

    .hero-video-btn:hover {
        background: rgba(0,0,0,0.8);
        border-color: rgba(255,255,255,0.4);
        transform: scale(1.05);
    }

    .hero-video-btn svg {
        width: 20px;
        height: 20px;
        stroke: currentColor;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .hero-video-btn .icon-unmuted {
        display: none;
    }

    .hero-video-btn.unmuted .icon-muted {
        display: none;
    }

    .hero-video-btn.unmuted .icon-unmuted {
        display: block;
    }

    /* ===========================
       FEATURES SECTION
       =========================== */
    .features-section {
        background: var(--color-white);
    }

    .section-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-fg-muted);
        margin-bottom: 14px;
        display: block;
    }

    .section-label-yellow { color: var(--color-accent-hover); }

    .section-heading {
        font-size: 48px;
        letter-spacing: -0.025em;
        margin-bottom: 16px;
    }

    .section-subtext {
        font-size: 18px;
        color: var(--color-fg-muted);
        max-width: 680px;
        line-height: 1.65;
    }

    .section-header {
        text-align: center;
        margin-bottom: 64px;
    }

    .section-header .section-subtext { margin: 0 auto; }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 28px;
    }

    .feature-card {
        background: var(--color-white);
        border: 1px solid var(--color-border-default);
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.3s cubic-bezier(0.4,0,0.2,1),
                    box-shadow 0.3s cubic-bezier(0.4,0,0.2,1),
                    border-color 0.3s cubic-bezier(0.4,0,0.2,1);
    }

    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
        border-color: var(--color-accent);
    }

    .feature-card-img {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        display: block;
    }

    .feature-card-body {
        padding: 28px 32px 32px;
    }

    .feature-card h3 {
        font-size: 20px;
        margin-bottom: 10px;
        color: var(--color-fg-default);
    }

    .feature-card p {
        font-size: 15px;
        line-height: 1.7;
        color: var(--color-fg-muted);
    }

    /* ===========================
       PRODUCT SHOWCASE
       =========================== */
    .showcase-section {
        background: var(--color-canvas-subtle);
    }

    .showcase-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    .showcase-visual {
        position: relative;
    }

    .showcase-img-main {
        width: 100%;
        aspect-ratio: 1;
        object-fit: cover;
        border-radius: 16px;
        box-shadow: var(--shadow-lg);
    }

    .showcase-img-thumb-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-top: 12px;
    }

    .showcase-img-thumb {
        aspect-ratio: 1;
        object-fit: cover;
        border-radius: 8px;
        cursor: pointer;
        opacity: 0.7;
        transition: opacity 0.2s, box-shadow 0.2s;
        border: 2px solid transparent;
    }

    .showcase-img-thumb:hover,
    .showcase-img-thumb.active {
        opacity: 1;
        border-color: var(--color-accent);
        box-shadow: var(--shadow-yellow);
    }

    .showcase-content { }

    .showcase-content h2 {
        font-size: 40px;
        letter-spacing: -0.025em;
        margin-bottom: 20px;
    }

    .showcase-content p {
        font-size: 17px;
        line-height: 1.75;
        color: var(--color-fg-muted);
        margin-bottom: 32px;
    }

    .spec-list {
        list-style: none;
        margin-bottom: 36px;
    }

    .spec-item {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 16px 0;
        border-bottom: 1px solid var(--color-border-muted);
    }

    .spec-item:first-child { border-top: 1px solid var(--color-border-muted); }

    .spec-check {
        width: 22px;
        height: 22px;
        background: var(--color-accent);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .spec-check svg {
        width: 12px;
        height: 12px;
        stroke: var(--color-black);
        fill: none;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .spec-text strong {
        display: block;
        font-size: 15px;
        font-weight: 600;
        color: var(--color-fg-default);
        margin-bottom: 2px;
    }

    .spec-text span {
        font-size: 14px;
        color: var(--color-fg-muted);
    }

    /* ===========================
       HOW IT WORKS
       =========================== */
    .hiw-section {
        background: var(--color-black);
        color: var(--color-white);
        position: relative;
        overflow: hidden;
    }

    .hiw-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .hiw-section .section-label { color: rgba(255,255,255,0.5); }
    .hiw-section .section-heading { color: var(--color-white); }
    .hiw-section .section-subtext { color: rgba(255,255,255,0.6); }

    .hiw-steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2px;
        position: relative;
        z-index: 1;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        overflow: hidden;
    }

    .hiw-step {
        padding: 48px 40px;
        background: rgba(255,255,255,0.03);
        border-right: 1px solid rgba(255,255,255,0.08);
        transition: background 0.3s;
        position: relative;
    }

    .hiw-step:last-child { border-right: none; }
    .hiw-step:hover { background: rgba(255,255,255,0.06); }

    .hiw-step-number {
        font-family: 'Inter Tight', sans-serif;
        font-size: 72px;
        font-weight: 900;
        color: rgba(250,204,21,0.12);
        line-height: 1;
        margin-bottom: 20px;
        letter-spacing: -0.04em;
    }

    .hiw-step-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
        margin-bottom: 10px;
        display: block;
    }

    .hiw-step h3 {
        font-size: 22px;
        color: var(--color-white);
        margin-bottom: 12px;
    }

    .hiw-step p {
        font-size: 15px;
        line-height: 1.7;
        color: rgba(255,255,255,0.6);
    }

    /* ===========================
       PRICING SECTION
       =========================== */
    .pricing-section {
        background: var(--color-white);
    }

    .pricing-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        max-width: 900px;
        margin: 0 auto;
    }

    .pricing-card {
        border: 1px solid var(--color-border-default);
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
        position: relative;
        display: flex;
        flex-direction: column;
        min-height: 600px;
    }

    .pricing-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
    }

    .pricing-card-featured {
        border-color: var(--color-accent);
        box-shadow: var(--shadow-yellow-lg);
    }

    .pricing-card-featured:hover {
        box-shadow: 0 20px 60px rgba(250,204,21,0.3);
    }

    .pricing-badge {
        background: var(--color-accent);
        color: var(--color-black);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 8px 20px;
        text-align: center;
    }

    .pricing-body {
        padding: 40px 36px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .pricing-name {
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-fg-muted);
        margin-bottom: 12px;
    }

    .pricing-price {
        display: flex;
        align-items: baseline;
        gap: 10px;
        margin-bottom: 6px;
    }

    .pricing-amount {
        font-family: 'Inter Tight', sans-serif;
        font-size: 52px;
        font-weight: 600;
        color: var(--color-fg-default);
        letter-spacing: -0.04em;
        line-height: 1;
    }

    .pricing-was {
        font-size: 18px;
        color: var(--color-fg-subtle);
        text-decoration: line-through;
    }

    .pricing-save {
        display: inline-block;
        align-self: flex-start;
        background: rgba(250,204,21,0.15);
        color: var(--color-accent-hover);
        font-size: 13px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 4px;
        margin-bottom: 24px;
    }

    .pricing-features {
        list-style: none;
        margin-bottom: 32px;
        flex: 1;
    }

    .pricing-features li {
        font-size: 14px;
        line-height: 1.6;
        color: var(--color-fg-muted);
        padding-left: 22px;
        margin-bottom: 10px;
        position: relative;
    }

    .pricing-features li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: var(--color-accent-hover);
        font-weight: 600;
    }

    /* ===========================
       TESTIMONIALS
       =========================== */
    .testimonials-section {
        background: var(--color-canvas-subtle);
    }

    .testimonials-slider-wrap {
        position: relative;
        overflow: hidden;
        width: 100%;
    }

    .testimonials-track {
        display: flex;
        flex-wrap: nowrap;
        width: 100%;
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        will-change: transform;
    }

    .testimonials-slide {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        width: 100%;
        min-width: 100%;
        flex: 0 0 100%;
        box-sizing: border-box;
    }

    .testimonials-dots {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-top: 40px;
    }

    .testimonials-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.18);
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        padding: 0;
        flex-shrink: 0;
    }

    .testimonials-dot:hover {
        background: rgba(0, 0, 0, 0.35);
    }

    .testimonials-dot.active {
        background: var(--color-accent);
        width: 32px;
        border-radius: 999px;
    }

    .testimonial-card {
        background: var(--color-white);
        border: 1px solid var(--color-border-default);
        border-radius: 10px;
        padding: 36px 32px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .testimonial-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }

    .testimonial-stars {
        display: flex;
        gap: 4px;
        margin-bottom: 20px;
    }

    .star {
        width: 18px;
        height: 18px;
        fill: var(--color-accent);
    }

    .testimonial-quote {
        font-size: 16px;
        line-height: 1.7;
        color: var(--color-fg-default);
        margin-bottom: 24px;
        font-style: italic;
    }

    .testimonial-author {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .testimonial-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--color-accent);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 600;
        color: var(--color-black);
        font-family: 'Inter Tight', sans-serif;
        flex-shrink: 0;
    }

    .testimonial-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--color-fg-default);
    }

    .testimonial-location {
        font-size: 13px;
        color: var(--color-fg-muted);
    }

    /* ===========================
       FAQ SECTION
       =========================== */
    .faq-section {
        background: var(--color-white);
    }

    .faq-inner {
        max-width: 800px;
        margin: 0 auto;
    }

    .faq-item {
        border-bottom: 1px solid var(--color-border-default);
    }

    .faq-item:first-child { border-top: 1px solid var(--color-border-default); }

    .faq-question {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 0;
        text-align: left;
        cursor: pointer;
        background: none;
        gap: 20px;
    }

    .faq-question:hover { background: rgba(0,0,0,0.01); }

    .faq-question h3 {
        font-size: 18px;
        font-weight: 600;
        color: var(--color-fg-default);
        flex: 1;
    }

    .faq-icon {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: var(--color-canvas-subtle);
        border: 1px solid var(--color-border-default);
        font-size: 18px;
        color: var(--color-fg-muted);
        transition: transform 0.3s, background 0.2s;
        flex-shrink: 0;
    }

    .faq-item.active .faq-icon {
        transform: rotate(45deg);
        background: var(--color-accent);
        border-color: var(--color-accent);
        color: var(--color-black);
    }

    .faq-answer {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s ease;
    }

    .faq-answer-inner {
        padding: 0 0 24px 0;
        font-size: 15px;
        line-height: 1.75;
        color: var(--color-fg-muted);
    }

    /* ===========================
       FINAL CTA
       =========================== */
    .final-cta {
        background: var(--color-black);
        color: var(--color-white);
        position: relative;
        overflow: hidden;
        text-align: center;
    }

    .final-cta::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
