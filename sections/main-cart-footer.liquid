{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}

<style>
  /* RADCam Cart Footer Styling */
  :root {
    --rc-color-black: #000000;
    --rc-color-white: #ffffff;
    --rc-color-accent: #facc15;
    --rc-color-accent-hover: #f5c400;
    --rc-color-canvas-subtle: #f6f8fa;
    --rc-color-border-default: #d0d7de;
    --rc-color-border-muted: #e1e4e8;
    --rc-color-fg-default: #0d1117;
    --rc-color-fg-muted: #57606a;
    --rc-shadow-yellow: 0 4px 12px rgba(250,204,21,0.25);
  }

  #main-cart-footer {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    padding-bottom: 60px;
  }

  #main-cart-footer.is-empty {
    display: none;
  }

  .cart__footer {
    padding-top: 40px;
    border-top: 2px solid var(--rc-color-border-muted);
  }

  .cart__blocks {
    max-width: 420px;
    margin-left: auto;
  }

  /* Totals */
  .totals {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--rc-color-border-muted);
  }

  .totals__subtotal {
    font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--rc-color-fg-default);
    margin: 0;
  }

  .totals__subtotal-value {
    font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--rc-color-black);
    margin: 0;
  }

  /* Tax note */
  .tax-note {
    font-size: 13px;
    color: var(--rc-color-fg-muted);
    text-align: right;
    margin-bottom: 24px;
    line-height: 1.5;
  }

  .tax-note a {
    color: var(--rc-color-fg-muted);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .tax-note a:hover {
    color: var(--rc-color-fg-default);
  }

  /* Cart note */
  .cart__note {
    margin-bottom: 24px;
  }

  .cart__note label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--rc-color-fg-default);
    margin-bottom: 8px;
  }

  .cart__note .text-area {
    width: 100%;
    min-height: 100px;
    padding: 14px;
    border: 1px solid var(--rc-color-border-default);
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: var(--rc-color-fg-default);
    resize: vertical;
    transition: border-color 0.2s, box-shadow 0.2s;
    background: var(--rc-color-white);
  }

  .cart__note .text-area:focus {
    outline: none;
    border-color: var(--rc-color-accent);
    box-shadow: 0 0 0 3px rgba(250, 204, 21, 0.15);
  }

  .cart__note .text-area::placeholder {
    color: var(--rc-color-fg-muted);
  }

  /* Checkout button */
  .cart__ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cart__checkout-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 32px;
    border-radius: 8px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 16px;
    font-weight: 600;
    background: var(--rc-color-accent);
    color: var(--rc-color-black);
    border: 2px solid var(--rc-color-accent);
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
    width: 100%;
  }

  .cart__checkout-button:hover {
    background: var(--rc-color-accent-hover);
    border-color: var(--rc-color-accent-hover);
    transform: translateY(-2px);
    box-shadow: var(--rc-shadow-yellow);
  }

  .cart__checkout-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .cart__update-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 24px;
    border-radius: 8px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 15px;
    font-weight: 600;
    background: transparent;
    color: var(--rc-color-fg-default);
    border: 1px solid var(--rc-color-border-default);
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
    width: 100%;
  }

  .cart__update-button:hover {
    background: var(--rc-color-canvas-subtle);
    border-color: var(--rc-color-fg-muted);
  }

  /* Dynamic checkout buttons */
  .cart__dynamic-checkout-buttons {
    margin-top: 16px;
  }

  .cart__dynamic-checkout-buttons [data-shopify-buttoncontainer] {
    justify-content: stretch;
  }

  /* Discounts in footer */
  #main-cart-footer .discounts {
    list-style: none;
    padding: 0;
    margin: 0 0 16px 0;
  }

  #main-cart-footer .discounts__discount {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: rgba(250, 204, 21, 0.15);
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--rc-color-fg-default);
    margin-bottom: 8px;
  }

  #main-cart-footer .discounts__discount svg {
    width: 16px;
    height: 16px;
    color: var(--rc-color-accent-hover);
  }

  /* Cart errors */
  #cart-errors {
    margin-top: 16px;
    padding: 12px 16px;
    background: rgba(220, 38, 38, 0.05);
    border: 1px solid rgba(220, 38, 38, 0.2);
    border-radius: 8px;
    color: #dc2626;
    font-size: 14px;
  }

  #cart-errors:empty {
    display: none;
  }

  /* Mobile responsive */
  @media screen and (max-width: 749px) {
    #main-cart-footer {
      padding-bottom: 40px;
    }

    .cart__footer {
      padding-top: 32px;
    }

    .cart__blocks {
      max-width: 100%;
    }

    .totals__subtotal-value {
      font-size: 24px;
    }

    .cart__checkout-button {
      padding: 14px 24px;
    }
  }
</style>

<div class="page-width{% if cart == empty %} is-empty{% endif %}" id="main-cart-footer" data-id="{{ section.id }}">
  <div>
    <div class="cart__footer">
      {%- if settings.show_cart_note -%}
        <cart-note class="cart__note field">
          <label for="Cart-note">{{ 'sections.cart.note' | t }}</label>
          <textarea
            class="text-area field__input"
            name="note"
            form="cart"
            id="Cart-note"
            placeholder="{{ 'sections.cart.note' | t }}"
          >{{ cart.note }}</textarea>
        </cart-note>
      {%- endif -%}

      <div class="cart__blocks">
        {% for block in section.blocks %}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'subtotal' -%}
              <div class="js-contents" {{ block.shopify_attributes }}>
                <div class="totals">
                  <h2 class="totals__subtotal">{{ 'sections.cart.subtotal' | t }}</h2>
                  <p class="totals__subtotal-value">{{ cart.total_price | money_with_currency }}</p>
                </div>

                <div>
                  {%- if cart.cart_level_discount_applications.size > 0 -%}
                    <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                      {%- for discount in cart.cart_level_discount_applications -%}
                        <li class="discounts__discount discounts__discount--position">
                          {%- render 'icon-discount' -%}
                          {{ discount.title }}
                          (-{{ discount.total_allocated_amount | money }})
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>

                <small class="tax-note caption-large rte">
                  {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                    {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
                  {%- elsif cart.taxes_included -%}
                    {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
                  {%- elsif shop.shipping_policy.body != blank -%}
                    {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
                  {%- else -%}
                    {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
                  {%- endif -%}
                </small>
              </div>
            {%- else -%}
              <div class="cart__ctas" {{ block.shopify_attributes }}>
                <noscript>
                  <button type="submit" class="cart__update-button button button--secondary" form="cart">
                    {{ 'sections.cart.update' | t }}
                  </button>
                </noscript>

                <button
                  type="submit"
                  id="checkout"
                  class="cart__checkout-button button"
                  name="checkout"
                  {% if cart == empty %}
                    disabled
                  {% endif %}
                  form="cart"
                >
                  {{ 'sections.cart.checkout' | t }}
                </button>
              </div>

              {%- if additional_checkout_buttons -%}
                <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}
          {%- endcase -%}
        {% endfor %}

        <div id="cart-errors"></div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function isIE() {
      const ua = window.navigator.userAgent;
      const msie = ua.indexOf('MSIE ');
      const trident = ua.indexOf('Trident/');

      return msie > 0 || trident > 0;
    }

    if (!isIE()) return;
    const cartSubmitInput = document.createElement('input');
    cartSubmitInput.setAttribute('name', 'checkout');
    cartSubmitInput.setAttribute('type', 'hidden');
    document.querySelector('#cart').appendChild(cartSubmitInput);
    document.querySelector('#checkout').addEventListener('click', function (event) {
      document.querySelector('#cart').submit();
    });
  });
</script>

{% schema %}
{
  "name": "t:sections.main-cart-footer.name",
  "class": "cart__footer-wrapper",
  "blocks": [
    {
      "type": "subtotal",
      "name": "t:sections.main-cart-footer.blocks.subtotal.name",
      "limit": 1
    },
    {
      "type": "buttons",
      "name": "t:sections.main-cart-footer.blocks.buttons.name",
      "limit": 1
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
